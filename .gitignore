# Ignore everything
*

# Except these files
!.gitignore
!bog.meta.tree
!.gitattributes
!README.md
!LICENSE

# Allow ui source code
!ui/
!ui/**/
!ui/**/*.tree
!ui/**/*.ts
!ui/**/*.css
!ui/**/*.html
!ui/**/*.svg
!ui/**/*.json
!ui/**/*.md

# Ignore MAM build output everywhere
**/-/
**/-view.tree/
**/-node/
**/-css/

# Allow GitHub Actions
!.github/
!.github/**/
!.github/**/*.yml

# Allow version component
!version/

# Allow qr source code
!qr/
!qr/**/
!qr/**/*.tree
!qr/**/*.ts
!qr/**/*.css
!qr/**/*.html
!qr/**/*.svg
!qr/**/*.json
!qr/**/*.md
# Re-ignore build output inside qr
qr/**/-/
qr/**/-view.tree/
qr/**/-node/
qr/**/-css/
