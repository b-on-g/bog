# Ignore everything
*

# Except these files
!.gitignore
!bog.meta.tree
!.gitattributes
!README.md
!LICENSE

# Allow ui source code
!ui/
!ui/**/
!ui/**/*.tree
!ui/**/*.ts
!ui/**/*.css
!ui/**/*.html
!ui/**/*.json
!ui/**/*.md

# But ignore build output
ui/**/-/
ui/**/-view.tree/
ui/**/-node/
ui/**/-css/

# Allow version component
!version/
!version/**/*.tree
!version/**/*.ts

# But ignore build output
version/**/-view.tree/
