$bog_notebookllm_app $mol_book2
	plugins /
		<= Theme $mol_theme_auto
	model_id \Qwen2.5-1.5B-Instruct-q4f16_1-MLC
	pages /
		<= Notebooks_page $mol_page
			title @ \Notebooks
			tools /
				<= Notebook_add $mol_button_minor
					hint @ \New notebook
					click? <=> notebook_add? null
					sub /
						<= Notebook_add_icon $mol_icon_plus
			body /
				<= Notebook_list $mol_list
					rows <= notebook_rows /
						<= Notebook_row*0 $mol_row
							event *
								^
								click? <=> notebook_select*? null
							sub /
								<= Notebook_icon* $mol_icon_notebook_outline
								<= Notebook_title* $mol_dimmer
									haystack <= notebook_title* \
									needle <= notebooks_filter \
								<= Notebook_delete* $mol_button_minor
									click? <=> notebook_delete*? null
									sub /
										<= Notebook_delete_icon* $mol_icon_trash_can_outline
		<= Dialog $mol_page
			title_content /
				\📓
				<= title <= dialog_title? @ \NotebookLLM
			body_content /
				<= Model_status $mol_view
					sub /
						<= model_status_text \Loading model...
				<= Messages $mol_list
					rows <= messages /
						<= Message*0 $mol_view sub /
							<= Message_text* $mol_text text <= message_text* \
			foot /
				<= Docs_bar $mol_row
					sub <= docs_bar_items /
						<= Doc_upload $mol_button_minor
							hint @ \Upload document
							click? <=> doc_upload_click? null
							sub /
								<= Doc_upload_icon $mol_icon_file_upload_outline
						<= Doc_count $mol_view
							sub /
								<= doc_count_text \
				<= Prompt_text $mol_textarea
					hint @ \Ask about your documents...
					value? <=> prompt_text? \
					submit? <=> prompt_submit? null
				<= Prompt_submit $mol_button_minor
					hint @ \Send
					click? <=> prompt_submit?
					sub /
						<= Prompt_submit_icon $mol_icon_send
	placeholders /
		<= Sources_page $mol_page
			title @ \Sources
			tools /
				<= Reset $mol_button_minor
					hint @ \Reset chat
					click? <=> reset? null
					sub /
						<= Reset_icon $mol_icon_trash_can_outline
				<= Lights $mol_lights_toggle
			body /
				<= Sources_info $mol_text
					text <= sources_info \
				<= Doc_list $mol_list
					rows <= doc_rows /
						<= Doc_row*0 $mol_row
							sub /
								<= Doc_icon* $mol_icon_file_document_outline
								<= Doc_name* $mol_view
									sub / <= doc_name* \
								<= Doc_remove* $mol_button_minor
									click? <=> doc_remove*? null
									sub /
										<= Doc_remove_icon* $mol_icon_close
				<= Digest $mol_text
					text <= digest? \
