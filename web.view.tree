$mol_list $mol_view
	render_visible_only true
	render_over 0.1
	sub <= rows /$mol_view
		<= Gap_before $mol_view style * paddingTop <= gap_before 0
		<= Empty $mol_view
		<= Gap_after $mol_view style * paddingTop <= gap_after 0
	item_height_min* 1
	item_width_min* 1
	view_window_shift? 0
	view_window /
		0
		0

$mol_icon_menu $mol_icon path \M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z

$bog_ui_sidebar $mol_view
	mode? \dock
	items /
	sub /
		<= Header $mol_view
			sub /
		<= Items $mol_list
			rows <= items_with_collapsed /
		<= Footer $mol_view
			sub /
		<= Toggle $mol_button_minor
			click? <=> toggle? null
			sub /
				<= Toggle_icon $mol_icon_menu
	attr *
		bog_ui_sidebar_mode <= mode?

$mol_check $mol_button_minor
	attr *
		^
		mol_check_checked <= checked? false
		aria-checked <= aria_checked \false
		role <= aria_role \checkbox
	sub /$mol_view_content
		<= Icon null
		<= label /
			<= Title $mol_view
				sub /
					<= title \

$mol_check_icon $mol_check

