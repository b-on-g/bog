$bog_ui_toast $mol_view
	message \
	type \info
	closeable true
	close? null
	sub /
		<= Icon $mol_icon_information
		<= Body $mol_view
			sub /
				<= message
		<= Close $mol_button_minor
			click? <=> close?
			sub /
				<= Close_icon $mol_icon_close
	attr *
		bog_ui_toast_type <= type
		bog_ui_toast_closeable <= closeable

$mol_icon_check $mol_icon path \M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z

$mol_icon_check_circle $mol_icon path \M12 2C6.5 2 2 6.5 2 12S6.5 22 12 22 22 17.5 22 12 17.5 2 12 2M10 17L5 12L6.41 10.59L10 14.17L17.59 6.58L19 8L10 17Z

$mol_icon_alert $mol_icon path \M13 14H11V9H13M13 18H11V16H13M1 21H23L12 2L1 21Z

$mol_icon_alert_circle $mol_icon path \M13,13H11V7H13M13,17H11V15H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z

$bog_ui_toast_manager $mol_view
	toast_data /
	Toast* $bog_ui_toast
		message <= toast_message* \
		type <= toast_type* \info
		close? <=> toast_close*? null
	sub <= toast_views /

$bog_ui_app_toast $mol_page
	title \Toast
	body /
		<= Description $mol_view
			sub /
				<= description \Toast notifications for user feedback. Click a button to trigger a toast of the corresponding type. Toasts stack vertically and close via the × button.
		<= Buttons_title $mol_view
			sub /
				<= buttons_title \Trigger toasts
		<= Buttons $mol_view
			sub /
				<= Info_button $mol_button_minor
					click? <=> add_info? null
					sub /
						<= info_label \Info
				<= Success_button $mol_button_minor
					click? <=> add_success? null
					sub /
						<= success_label \Success
				<= Warning_button $mol_button_minor
					click? <=> add_warning? null
					sub /
						<= warning_label \Warning
				<= Error_button $mol_button_minor
					click? <=> add_error? null
					sub /
						<= error_label \Error
		<= Manager $bog_ui_toast_manager

$bog_ui_app_command $mol_page
	title \Command Palette
	body /
		<= Description $mol_view
			sub /
				<= description \Command palette for quick search and action execution. Press the button or use ⌘K / Ctrl+K to open. Type to filter commands in real time.
		<= Open_title $mol_view
			sub /
				<= open_title \Open palette
		<= Open_row $mol_view
			sub /
				<= Open_button $mol_button_minor
					click? <=> open_palette? null
					sub /
						<= open_label \Open Command Palette
				<= Shortcut_hint $mol_view
					sub /
						<= shortcut_hint \⌘K
		<= Groups_title $mol_view
			sub /
				<= groups_title \Demo commands
		<= Groups_desc $mol_view
			sub /
				<= groups_desc \The palette contains 3 groups: Navigation, Actions, and Settings. Use the search field to filter by command name.
		<= Palette $bog_ui_command
			showed? <=> palette_showed? false
			commands <= demo_commands /
				<= Nav_group $bog_ui_command_group
					title \Navigation
				<= Nav_home $bog_ui_command_item
					label \Go to Home
					shortcut \⌘H
				<= Nav_dashboard $bog_ui_command_item
					label \Go to Dashboard
					shortcut \⌘D
				<= Nav_settings $bog_ui_command_item
					label \Go to Settings
					shortcut \⌘,
				<= Nav_profile $bog_ui_command_item
					label \Go to Profile
				<= Actions_group $bog_ui_command_group
					title \Actions
				<= Actions_new $bog_ui_command_item
					label \Create New Item
					shortcut \⌘N
				<= Actions_save $bog_ui_command_item
					label \Save Current
					shortcut \⌘S
				<= Actions_export $bog_ui_command_item
					label \Export as PDF
					shortcut \⌘⇧E
				<= Settings_group $bog_ui_command_group
					title \Settings
				<= Settings_theme $bog_ui_command_item
					label \Toggle Dark Mode
					shortcut \⌘⇧T
				<= Settings_lang $bog_ui_command_item
					label \Change Language
				<= Settings_notifications $bog_ui_command_item
					label \Notification Settings

$mol_paragraph $mol_view
	line_height 24
	letter_width 7
	width_limit +Infinity
	row_width 0
	sub / <= title

$mol_dimmer $mol_paragraph
	haystack \
	needle \
	sub <= parts /$mol_view_content
	Low* $mol_paragraph
		sub /
			<= string* \
	High* $mol_paragraph
		sub /
			<= string* \

$mol_float $mol_view
	style *
		^
		minHeight \auto

$mol_icon_chevron $mol_icon path \M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z

$mol_check_expand $mol_check
	Icon $mol_icon_chevron
	level 0
	style *
		^
		paddingLeft <= level_style \0px
	checked? <=> expanded? false
	enabled <= expandable false

$mol_grid $mol_view
	row_height 32
	row_ids /string[]
	row_id* null
	col_ids /
	records *
	record* null
	hierarchy null
	hierarchy_col \
	minimal_width 0
	-
	sub /
		<= Head
		<= Table $mol_grid_table
			sub <= rows /$mol_view
	Head $mol_grid_row
		cells <= head_cells /$mol_view
	Row* $mol_grid_row
		minimal_height <= row_height
		minimal_width <= minimal_width
		cells <= cells* /$mol_view
	-
	Cell* $mol_view
	cell* null
	Cell_text* $mol_grid_cell
		sub <= cell_content_text* <= cell_content* /$mol_view_content
	Cell_number* $mol_grid_number
		sub <= cell_content_number* <= cell_content* /$mol_view_content
	Col_head* $mol_float
		dom_name \th
		sub <= col_head_content* /$mol_view_content
	Cell_branch* $mol_check_expand
		level <= cell_level* 0
		label <= cell_content* /$mol_view_content
		expanded? <=> cell_expanded*? false
	Cell_content* /
		<= Cell_dimmer* $mol_dimmer
			needle <= needle \
			haystack <= cell_value* \

$mol_grid_table $mol_list
	- dom_name \table

$mol_grid_row $mol_view
	- dom_name \tr
	sub <= cells /$mol_view

$mol_grid_cell $mol_view
	- dom_name \td
	minimal_height 40

$mol_grid_number $mol_grid_cell

$mol_icon_tick $mol_icon path \M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z

$mol_check_box $mol_check
	Icon $mol_icon_tick

$bog_ui_table $mol_grid
	columns /
	data /
	sort_column? \
	sort_dir? \asc
	selectable false
	selected? /
	all_selected? false
	row_checked*? false
	Row* $mol_grid_row
		minimal_height <= row_height
		minimal_width <= minimal_width
		cells <= cells* /$mol_view
		attr *
			^
			bog_ui_table_row_even <= row_even* false
			bog_ui_table_row_selected <= row_selected* false
	Head_button* $mol_button_minor
		click? <=> col_head_click*? null
		sub / <= head_button_content* /
	Select_all $mol_check_box
		checked? <=> all_selected? false
	Select_row* $mol_check_box
		checked? <=> row_checked*? false

$bog_ui_app_table $mol_page
	title \Data Table
	body /
		<= Description $mol_view
			sub /
				<= description \Data table with sorting, row selection, and zebra striping. Click column headers to sort. Use checkboxes to select rows.
		<= Selected_info $mol_view
			sub /
				<= selected_text \No rows selected
		<= Table $bog_ui_table
			columns <= columns /
			data <= data /
			selectable true
			selected? <=> selected? /
			sort_column? <=> sort_column? \
			sort_dir? <=> sort_dir? \asc

$bog_ui_app_overview $mol_page
	title \Components Overview
	body /
		<= Description $mol_view
			sub /
				<= description \Browse all available UI components. Click a card to see its full demo.
		<= Grid $mol_view
			sub <= cards /
				<= Card_badge $bog_ui_app_overview_card
					card_id \badge
					card_title \Badge
					card_description \Compact label with 5 color variants for status indication
					click? <=> go_badge? null
					Preview <= Badge_preview $mol_view
						sub /
							<= Badge_s $bog_ui_badge
								label \Success
								type \success
							<= Badge_e $bog_ui_badge
								label \Error
								type \error
							<= Badge_i $bog_ui_badge
								label \Info
								type \info
				<= Card_empty $bog_ui_app_overview_card
					card_id \empty
					card_title \Empty State
					card_description \Placeholder for pages with no content
					click? <=> go_empty? null
					Preview <= Empty_preview $mol_view
						sub /
							<= Empty_icon $mol_icon_magnify
							<= Empty_text $mol_view
								sub /
									\No results
				<= Card_skeleton $bog_ui_app_overview_card
					card_id \skeleton
					card_title \Skeleton
					card_description \Loading placeholder with shimmer animation
					click? <=> go_skeleton? null
					Preview <= Skeleton_preview $mol_view
						sub /
							<= Skel_1 $bog_ui_skeleton
							<= Skel_2 $bog_ui_skeleton
							<= Skel_3 $bog_ui_skeleton
				<= Card_breadcrumb $bog_ui_app_overview_card
					card_id \breadcrumb
					card_title \Breadcrumb
					card_description \Navigation breadcrumb trail with separator
					click? <=> go_breadcrumb? null
					Preview <= Breadcrumb_preview $mol_view
						sub /
							<= Bc_home $mol_view
								sub / \Home
							<= Bc_sep $mol_view
								sub / \>
							<= Bc_cat $mol_view
								sub / \Catalog
							<= Bc_sep2 $mol_view
								sub / \>
							<= Bc_cur $mol_view
								sub / \Page
				<= Card_sidebar $bog_ui_app_overview_card
					card_id \sidebar
					card_title \Sidebar
					card_description \Side navigation panel with 3 display modes
					click? <=> go_sidebar? null
					Preview <= Sidebar_preview $mol_view
						sub /
							<= Sb_bar $mol_view
								sub /
									<= Sb_i1 $mol_icon_home
									<= Sb_i2 $mol_icon_account
									<= Sb_i3 $mol_icon_cog
							<= Sb_content $mol_view
								sub /
									\Content
				<= Card_sheet $bog_ui_app_overview_card
					card_id \sheet
					card_title \Sheet
					card_description \Overlay panel sliding from screen edge
					click? <=> go_sheet? null
					Preview <= Sheet_preview $mol_view
						sub /
							<= Sheet_box $mol_view
								sub /
									<= Sheet_panel $mol_view
										sub /
											\Panel
				<= Card_toast $bog_ui_app_overview_card
					card_id \toast
					card_title \Toast
					card_description \Notification messages with 4 severity types
					click? <=> go_toast? null
					Preview <= Toast_preview $mol_view
						sub /
							<= Toast_info_mini $mol_view
								sub /
									<= Toast_info_icon $mol_icon_information
									\Info message
							<= Toast_ok_mini $mol_view
								sub /
									<= Toast_ok_icon $mol_icon_check_circle
									\Success!
				<= Card_command $bog_ui_app_overview_card
					card_id \command
					card_title \Command Palette
					card_description \Search and execute commands via keyboard
					click? <=> go_command? null
					Preview <= Command_preview $mol_view
						sub /
							<= Cmd_search $mol_view
								sub /
									<= Cmd_icon $mol_icon_magnify
									\Search commands...
				<= Card_table $bog_ui_app_overview_card
					card_id \table
					card_title \Data Table
					card_description \Sortable data grid with row selection
					click? <=> go_table? null
					Preview <= Table_preview $mol_view
						sub /
							<= Tbl_head $mol_view
								sub /
									\Name
									\Email
									\Role
							<= Tbl_row1 $mol_view
								sub /
									\Alice
									\a@b.c
									\Dev
							<= Tbl_row2 $mol_view
								sub /
									\Bob
									\b@b.c
									\PM

$bog_ui_app_overview_card $mol_button_minor
	card_id \
	card_title \
	card_description \
	Preview $mol_view
	attr *
		^
		bog_ui_app_overview_card true
	sub /
		<= Preview
		<= Title $mol_view
			sub /
				<= card_title
		<= Card_desc $mol_view
			sub /
				<= card_description

$bog_ui_divider $mol_view
	dom_name \hr

$bog_ui_app_divider $mol_page
	title \Divider
	body /
		<= Description $mol_view
			sub /
				<= description \Horizontal line to separate content.
		<= Divider $bog_ui_divider

$bog_ui_app $mol_book2
	plugins /
		^
		<= Theme $mol_theme_auto
	event *
		^
		keydown? <=> global_keydown? null
	command_showed? false
	Command $bog_ui_command
		showed? <=> command_showed?
	Badge_page $bog_ui_app_badge
	Empty_page $bog_ui_app_empty
	Skeleton_page $bog_ui_app_skeleton
	Breadcrumb_page $bog_ui_app_breadcrumb
	Sidebar_page $bog_ui_app_sidebar
	Sheet_page $bog_ui_app_sheet
	Toast_page $bog_ui_app_toast
	Command_page $bog_ui_app_command
	Table_page $bog_ui_app_table
	Overview_page $bog_ui_app_overview
	Divider_page $bog_ui_app_divider
	pages /
		<= Nav $bog_ui_sidebar
			mode? <=> sidebar_mode? \dock
			items /
				<= Overview_nav $bog_ui_sidebar_item
					Icon <= Overview_icon $mol_icon_view_grid
					label \Overview
					active <= overview_active false
					click? <=> nav_overview? null
				<= Badge_nav $bog_ui_sidebar_item
					Icon <= Badge_icon $mol_icon_tag
					label \Badge
					active <= badge_active false
					click? <=> nav_badge? null
				<= Empty_nav $bog_ui_sidebar_item
					Icon <= Empty_icon $mol_icon_file
					label \Empty State
					active <= empty_active false
					click? <=> nav_empty? null
				<= Skeleton_nav $bog_ui_sidebar_item
					Icon <= Skeleton_icon $mol_icon_rectangle
					label \Skeleton
					active <= skeleton_active false
					click? <=> nav_skeleton? null
				<= Breadcrumb_nav $bog_ui_sidebar_item
					Icon <= Breadcrumb_icon $mol_icon_navigation
					label \Breadcrumb
					active <= breadcrumb_active false
					click? <=> nav_breadcrumb? null
				<= Sidebar_nav $bog_ui_sidebar_item
					Icon <= Sidebar_icon $mol_icon_dock_left
					label \Sidebar
					active <= sidebar_active false
					click? <=> nav_sidebar? null
				<= Sheet_nav $bog_ui_sidebar_item
					Icon <= Sheet_icon $mol_icon_card
					label \Sheet
					active <= sheet_active false
					click? <=> nav_sheet? null
				<= Toast_nav $bog_ui_sidebar_item
					Icon <= Toast_icon $mol_icon_bell
					label \Toast
					active <= toast_active false
					click? <=> nav_toast? null
				<= Command_nav $bog_ui_sidebar_item
					Icon <= Command_icon $mol_icon_console
					label \Command
					active <= command_active false
					click? <=> nav_command? null
				<= Table_nav $bog_ui_sidebar_item
					Icon <= Table_icon $mol_icon_table
					label \Data Table
					active <= table_active false
					click? <=> nav_table? null
				<= Divider_nav $bog_ui_sidebar_item
					Icon <= Divider_icon $mol_icon_minus
					label \Divider
					active <= divider_active false
					click? <=> nav_divider? null
		<= Content_page $mol_page
			title <= page_title \Components
			tools /
				<= Theme_toggle $mol_lights_toggle
			body /
				<= Page_body $mol_view
					sub /
						<= page_text \Select a component from the sidebar
