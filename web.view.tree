$bog_ui_app_sidebar $mol_page
	title \Sidebar
	body /
		<= Description $mol_view
			sub /
				<= description \Navigation sidebar with 3 display modes: dock (full width with labels), rail (icons only), and hidden (collapsed).
		<= Mode_title $mol_view
			sub /
				<= mode_title \Mode Switching
		<= Mode_buttons $mol_view
			sub /
				<= Dock_button $mol_button_minor
					click? <=> set_dock? null
					sub /
						<= dock_label \Dock
				<= Rail_button $mol_button_minor
					click? <=> set_rail? null
					sub /
						<= rail_label \Rail
				<= Hidden_button $mol_button_minor
					click? <=> set_hidden? null
					sub /
						<= hidden_label \Hidden
		<= Current_mode $mol_view
			sub /
				<= current_mode_text \Current mode: dock
		<= Preview $mol_view
			sub /
				<= Preview_sidebar $bog_ui_sidebar
					mode? <=> preview_mode? \dock
					items /
						<= Preview_item_home $bog_ui_sidebar_item
							Icon <= Preview_icon_home $mol_icon_home
							label \Home
						<= Preview_item_users $bog_ui_sidebar_item
							Icon <= Preview_icon_users $mol_icon_account
							label \Users
						<= Preview_item_settings $bog_ui_sidebar_item
							Icon <= Preview_icon_settings $mol_icon_cog
							label \Settings
				<= Preview_content $mol_view
					sub /
						<= preview_content_text \Main content area

$bog_ui_sheet $mol_view
	showed? false
	side \right
	content /
	sub /
		<= Backdrop $mol_view
			event *
				click? <=> backdrop_click? null
		<= Panel $mol_view
			sub /
				<= Content $mol_list
					rows <= content
	attr *
		bog_ui_sheet_showed <= showed?
		bog_ui_sheet_side <= side

$bog_ui_app_sheet $mol_page
	title \Sheet / Drawer
	body /
		<= Description $mol_view
			sub /
				<= description \Overlay panel that slides in from any edge of the screen. Click a button to open a Sheet from the corresponding side.
		<= Buttons_title $mol_view
			sub /
				<= buttons_title \Open from side
		<= Buttons $mol_view
			sub /
				<= Top_button $mol_button_minor
					click? <=> open_top? null
					sub /
						<= top_label \Top
				<= Right_button $mol_button_minor
					click? <=> open_right? null
					sub /
						<= right_label \Right
				<= Bottom_button $mol_button_minor
					click? <=> open_bottom? null
					sub /
						<= bottom_label \Bottom
				<= Left_button $mol_button_minor
					click? <=> open_left? null
					sub /
						<= left_label \Left
		<= Sheet_top $bog_ui_sheet
			showed? <=> top_showed? false
			side \top
			content /
				<= Top_content $mol_view
					sub /
						<= Top_heading $mol_view
							sub /
								<= top_heading \Sheet from Top
						<= Top_text $mol_view
							sub /
								<= top_text \This sheet slides in from the top edge. It can be used for notifications, search bars, or any content that should appear from above.
		<= Sheet_right $bog_ui_sheet
			showed? <=> right_showed? false
			side \right
			content /
				<= Right_content $mol_view
					sub /
						<= Right_heading $mol_view
							sub /
								<= right_heading \Sheet from Right
						<= Right_text $mol_view
							sub /
								<= right_text \This sheet slides in from the right edge. Commonly used for detail panels, settings, or secondary navigation.
						<= Right_form_title $mol_view
							sub /
								<= right_form_title \Example Form
						<= Right_name $mol_string
							hint \Your name
							value? <=> right_name? \
						<= Right_email $mol_string
							hint \Email address
							value? <=> right_email? \
		<= Sheet_bottom $bog_ui_sheet
			showed? <=> bottom_showed? false
			side \bottom
			content /
				<= Bottom_content $mol_view
					sub /
						<= Bottom_heading $mol_view
							sub /
								<= bottom_heading \Sheet from Bottom
						<= Bottom_text $mol_view
							sub /
								<= bottom_text \This sheet slides in from the bottom edge. Often used for mobile action sheets, media players, or supplementary content.
		<= Sheet_left $bog_ui_sheet
			showed? <=> left_showed? false
			side \left
			content /
				<= Left_content $mol_view
					sub /
						<= Left_heading $mol_view
							sub /
								<= left_heading \Sheet from Left
						<= Left_text $mol_view
							sub /
								<= left_text \This sheet slides in from the left edge. Useful for navigation drawers, filters, or side panels.

$mol_icon_information $mol_icon path \M13,9H11V7H13M13,17H11V11H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z

