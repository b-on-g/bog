$mol_button_major $mol_button_minor
	theme \$mol_theme_base

$bog_ui_app_empty $mol_page
	title \Empty State
	body /
		<= Description $mol_view
			sub /
				<= description \Placeholder component for empty pages with icon, title, message, and optional action button.
		<= Section_default $mol_view
			sub /
				<= section_default_title \Default
		<= Default $bog_ui_empty
		<= Section_custom $mol_view
			sub /
				<= section_custom_title \Custom Icon
		<= Custom_icon $bog_ui_empty
			Icon <= Custom_icon_icon $mol_icon_folder
			title \No documents
			message \Upload your first document to get started
		<= Section_action $mol_view
			sub /
				<= section_action_title \With Action Button
		<= With_action $bog_ui_empty
			Icon <= Action_icon $mol_icon_plus_circle
			title \No items yet
			message \Create your first item to begin
			Action <= Action_button $mol_button_major
				sub /
					<= action_label \Create Item

$bog_ui_skeleton $mol_view

$bog_ui_app_skeleton $mol_page
	title \Skeleton
	body /
		<= Description $mol_view
			sub /
				<= description \Loading placeholder with shimmer animation. Use to indicate content is being loaded.
		<= Section_single $mol_view
			sub /
				<= section_single_title \Single Line
		<= Single $bog_ui_skeleton
		<= Section_card $mol_view
			sub /
				<= section_card_title \Card Placeholder
		<= Card $mol_view
			sub /
				<= Card_avatar $bog_ui_skeleton
				<= Card_title $bog_ui_skeleton
				<= Card_line1 $bog_ui_skeleton
				<= Card_line2 $bog_ui_skeleton
				<= Card_short $bog_ui_skeleton
		<= Section_sizes $mol_view
			sub /
				<= section_sizes_title \Different Sizes
		<= Sizes $mol_view
			sub /
				<= Size_small $bog_ui_skeleton
				<= Size_medium $bog_ui_skeleton
				<= Size_large $bog_ui_skeleton

