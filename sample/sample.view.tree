$bog_sample $mol_book2
	plugins /
		<= Theme $mol_theme_auto
	pages /
	Home $mol_page
		title \Home
		body /
			<= Home_intro $mol_view
				sub /
					\Welcome to the sample app
			<= Home_to_about $mol_link
				arg * page \about
				sub /
					\About →
			<= Home_to_posts $mol_link
				arg * page \posts
				sub /
					\Posts →
	About $mol_page
		title \About
		body /
			<= About_text $mol_view
				sub /
					\Demo app for the SEO server. Shows prerender, meta, sitemap, robots and llms.
			<= About_back $mol_link
				arg * page null
				sub /
					\← Home
	Posts $mol_page
		title \Posts
		body /
			<= Posts_list $mol_list rows <= posts_rows /
			<= Posts_back $mol_link
				arg * page null
				sub /
					\← Home
	Post_row* $mol_view
		sub /
			<= Post_title* $mol_view
				sub /
					<= post_title* \
			<= Post_body* $mol_view
				sub /
					<= post_body* \
