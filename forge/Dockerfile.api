FROM node:24-alpine AS build
WORKDIR /app
RUN apk add --no-cache git python3 make g++ \
    && git clone --depth 1 https://github.com/hyoo-ru/mam.git . \
    && npm install
COPY . bog/forge/
RUN npx mam bog/forge/api

FROM node:24-alpine
WORKDIR /app
COPY --from=build /app/bog/forge/api/- /app/bog/forge/api/-
RUN mkdir -p /data
EXPOSE 9092
CMD ["node", "bog/forge/api/-/node.js"]
